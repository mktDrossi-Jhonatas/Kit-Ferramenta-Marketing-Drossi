# Copie este arquivo para ".env" (sem o .example) e preencha com seus valores reais.
# O ".env" nunca deve ser commitado — já está no .gitignore.

# Sua API key da Magnific (pegue em "Get your API key" no site do Magnific)
MAGNIFIC_API_KEY=

# ID de cada flow criado no Magnific (aparece na URL do curl de exemplo de cada flow).
MAGNIFIC_FLOW_ID_AMBIENTE=kh016BU1GT
MAGNIFIC_FLOW_ID_COR_TEXTURA=46Lw9AaisN

# Quanto cada geração custa em créditos da sua conta Magnific.
# Usado só para o contador local por IP — não consulta o saldo real da Magnific.
CREDIT_COST_PER_RUN=87

# Limite padrão de créditos para um IP novo que ainda não apareceu na lista.
# 435 = 5 gerações (87 créditos cada). Pode ser ajustado por IP depois, na aba de Logs.
# Deixe vazio para começar sem limite.
DEFAULT_CREDIT_LIMIT=435

# Porta do servidor (se estiver ocupada, ele tenta a próxima automaticamente)
PORT=3500
